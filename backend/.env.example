# ── App ─────────────────────────────────────────────
APP_ENV=local
API_V1_PREFIX=/api/v1
TZ=Asia/Seoul

# ── Database / Cache ────────────────────────────────
DATABASE_URL=postgresql+psycopg://bizradar:bizradar@localhost:5433/bizradar  # docker-compose.dev.yml: host 5433 (로컬 5432 충돌 회피)
REDIS_URL=redis://localhost:6379/0

# ── Auth (auth-onboarding.md) ───────────────────────
JWT_ALG=HS256
JWT_SECRET=change-me                 # Secret Manager (운영)
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14
PASSWORD_HASH=argon2id

# ── Collectors (data-ingestion / p0-source-spec) ────
INGEST_BUFFER_DAYS=2
INGEST_BACKFILL_DAYS=90
INGEST_MAX_PAGES=200
HTTP_TIMEOUT_CONNECT=5
HTTP_TIMEOUT_READ=30

NARAJANGTER_SERVICE_KEY=             # data.go.kr Decoding 키 (3개 서비스 공유)
# base는 /1230000 뒤 서비스 prefix(/ad,/as,/ao) 포함 필수 — 누락 시 404.
NARAJANGTER_BASE_URL=https://apis.data.go.kr/1230000/ad/BidPublicInfoService          # 15129394 입찰공고
NARAJANGTER_SCSBID_BASE_URL=https://apis.data.go.kr/1230000/as/ScsbidInfoService      # 15129397 낙찰(다음 단계)
NARAJANGTER_OPNSTD_BASE_URL=https://apis.data.go.kr/1230000/ao/PubDataOpnStdService   # 15058815 표준개방(미사용)
BIZINFO_CRTFC_KEY=                   # 기업마당 자체 발급 키 (data.go.kr 키와 별개, 이메일 수령)
BIZINFO_BASE_URL=https://www.bizinfo.go.kr/uss/rss/bizinfoApi.do
BIZINFO_PAGE_UNIT=100                # 페이지당 건수
INGEST_SEEN_STREAK_STOP=50          # 역순 cutoff 연속 seen 임계(서버 날짜필터 부재)
DETAIL_HTTP_DELAY_MS=500            # 상세 페이지 정중한 요청 간격(ms)
LLM_DETAIL_MODEL=claude-opus-4-8    # 상세 보강 추출(최신 Claude)
KSTARTUP_SERVICE_KEY=                # data.go.kr 15125364
KSTARTUP_BASE_URL=https://apis.data.go.kr/B552735/kisedKstartupService01
NTIS_MODE=api                        # api(15074634) | scrape
NTIS_SERVICE_KEY=                    # data.go.kr serviceKey (별도 NTIS 키 불필요)
NTIS_BASE_URL=http://apis.data.go.kr/1721000/msitannouncementinfo

# 수집 스케줄 (KST). 매일 09:00 입찰공고 증분 수집.
COLLECT_SCHEDULE_HOUR=9
COLLECT_SCHEDULE_MINUTE=0

# ── Embedding (벡터 = PostgreSQL pgvector, 별도 벡터 DB 없음) ───
EMBEDDING_PROVIDER=bge               # bge (OSS, fastembed, 키 불필요) | 확장 시 추가 가능
EMBEDDING_MODEL=BAAI/bge-m3          # dense 1024차원, 다국어(한국어 포함)
EMBEDDING_DIM=1024                   # pgvector vector(N) 차원(변경 시 마이그레이션)
EMBEDDING_VERSION=bge-m3:v1
# VOYAGE_API_KEY=                    # 제거 — voyage → fastembed BGE 교체
# Qdrant 제거 → pgvector. (복귀 시 QDRANT_URL/API_KEY + compose qdrant 복원)

# ── Matching (matching-engine) ──────────────────────
MATCH_THRESHOLD=70
MATCH_RETRIEVAL_TOP_N=50
LLM_MODEL=claude-opus-4-8            # 근거 생성 (최신 Claude)
ANTHROPIC_API_KEY=

# ── Notification (daily-briefing) ───────────────────
KAKAO_PROVIDER=solapi                # solapi | nhn_cloud
KAKAO_SENDER_KEY=
KAKAO_TEMPLATE_BRIEFING=
NOTIFY_SEND_HOUR=8
NOTIFY_FALLBACK_SMS=true
BRIEFING_TOP_N=3

# ── Billing (billing.md) — 사업자 확보 전 test 모드 ──
PAYMENT_PROVIDER=toss
TOSS_MODE=test                       # test | live
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
BILLING_PLAN_DEFAULT=basic_monthly
